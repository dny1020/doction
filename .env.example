# Password for the `doction` Postgres role — CHANGE THIS. Generate with: openssl rand -hex 24
# compose.yaml/infra/compose.yaml build DATABASE_URL from this automatically.
POSTGRES_PASSWORD=change-me

# Key used to sign JWTs — CHANGE THIS. Generate with: openssl rand -hex 32
SECRET_KEY=change-me

# Set to 1 when running behind a TLS-terminating reverse proxy
SECURE_COOKIES=0

# Set to 1 to enable local semantic search (sgrep / rag). The model ships in the image.
SEMANTIC_SEARCH=0

# Root logger level (DEBUG/INFO/WARNING/ERROR). Logs go to stdout and to a rotated
# file under LOG_DIR (in Docker: /logs, mounted as its own volume).
LOG_LEVEL=INFO
LOG_DIR=/logs
