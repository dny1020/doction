# Path to the SQLite database file
DATABASE_PATH=/data/doction.db

# Secret key for session signing — change this in production
SECRET_KEY=change-me

# Directory where the sentence-transformers model is cached (~80 MB, downloads on first boot)
SENTENCE_TRANSFORMERS_HOME=/data/models

# MCP server — exposes doction to AI agents at /mcp (HTTP transport)
# DOCTION_EMAIL + DOCTION_PASSWORD authenticate the MCP session at startup
# MCP_SECRET is the Bearer token Claude Code uses to connect
DOCTION_EMAIL=you@example.com
DOCTION_PASSWORD=yourpassword
MCP_SECRET=change-me
